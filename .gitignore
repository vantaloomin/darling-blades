# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────
dist/

# ── Vite ──────────────────────────────────────────────────────────────────
*.local

# ── Local-only dev modules (personal cheats / scratch tools; never committed) ─
# Loaded in dev by the import.meta.glob('./dev/*.local.ts') hook in src/main.ts.
# NOTE: the `*.local` rule above does NOT cover these (it only matches names
# ending in `.local`), so this explicit `*.local.ts` rule is required.
*.local.ts

# ── Generated art manifest (rebuilt by `npm run gen-art-manifest`) ────────
src/data/art-manifest.json

# ── Derived half-res mobile art (rebuilt by `npm run gen-art-halfres`) ────
public/assets/art/cards-half/

# ── Local-only balance workbench (card reference + power analysis; never committed) ─
balance/
scripts/card-reference.ts

# ── Logs ──────────────────────────────────────────────────────────────────
.artcrop-staging/

*.log

# ── Local Claude Code settings (launch.json is tracked; local overrides not)
.claude/settings.local.json

# (src-tauri/target and src-tauri/gen/schemas are ignored by src-tauri/.gitignore)
