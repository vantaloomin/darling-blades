# Normalize line endings: store as LF in the repo, convert on checkout as needed.
* text=auto eol=lf

# Windows batch launchers must keep CRLF or they can misbehave when run.
*.bat text eol=crlf

# Binary assets — never touch line endings, never try to diff/merge as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
