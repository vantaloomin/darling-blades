{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Darling Blades",
  "version": "1.3.0",
  "identifier": "com.loominvanta.darlingblades",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Darling Blades",
        "width": 1920,
        "height": 1080,
        "minWidth": 960,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Game",
    "shortDescription": "A single-player MTG-style collectible card game.",
    "longDescription": "Darling Blades — a single-player, MTG-style collectible card game with a seeded, deterministic engine, an avatar gauntlet, pack opening, deck building, and procedurally generated audio.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
